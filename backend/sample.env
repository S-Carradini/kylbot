# Copy this file to ./.env and fill in the values.
# Do NOT commit .env — it is gitignored.
# IMPORTANT: Use your own OpenAI API key, separate from any other project
# (e.g. Waterbot). Sharing a key would let one project's usage/billing mix
# with the other's.

# ── LLM ─────────────────────────────────────────────────
# Required. Used for chat responses, moderation, and translation.
OPENAI_API_KEY=sk-...

# ── Frontend origin (CORS) ───────────────────────────────
# The URL the React frontend is served from.
FRONTEND_URL=http://localhost:5173

# ── Session ───────────────────────────────────────────────
# Optional. If omitted, a random key is generated each restart
# (sessions won't survive restarts).
# SESSION_SECRET=
